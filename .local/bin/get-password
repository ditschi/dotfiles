#!/usr/bin/env bash
set -euo pipefail

# Retrieve a stored password from the GNOME keyring via secret-tool.
# Falls back to the $PASSWORD environment variable.
# Usage: get-password [USERNAME]   (defaults to the current user)

user="${1:-$(id -un)}"
result=""

if command -v secret-tool >/dev/null 2>&1; then
    result=$(secret-tool lookup password "$user" 2>/dev/null || true)
fi

if [[ -n ${result:-} ]]; then
    echo "$result"
    exit 0
fi

if [[ -n ${PASSWORD:-} ]]; then
    echo "$PASSWORD"
    exit 0
fi

echo "get-password: no password found in keyring or \$PASSWORD for user '$user'" >&2
exit 1
