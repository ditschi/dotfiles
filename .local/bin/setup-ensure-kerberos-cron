#!/usr/bin/env bash
set -euo pipefail

# Install or remove a user crontab entry that runs ensure-kerberos-token regularly.
# Usage: setup-ensure-kerberos-cron --install [--freq MINUTES]
#        setup-ensure-kerberos-cron --update  [--freq MINUTES]
#        setup-ensure-kerberos-cron --uninstall

FREQ=15
ACTION=install

while [[ $# -gt 0 ]]; do
    case "$1" in
        --install)
            ACTION=install
            shift
            ;;
        --update)
            ACTION=update
            shift
            ;;
        --uninstall)
            ACTION=uninstall
            shift
            ;;
        --freq)
            FREQ="$2"
            shift 2
            ;;
        -h | --help)
            echo "Usage: $0 --install [--freq MINUTES] | --update [--freq MINUTES] | --uninstall"
            exit 0
            ;;
        *)
            echo "Unknown arg: $1" >&2
            exit 2
            ;;
    esac
done

HOME_DIR=${HOME:-$(getent passwd "$(id -un)" | cut -d: -f6)}
USER_ID=$(id -u)
SCRIPT_PATH="$HOME_DIR/.local/bin/ensure-kerberos-token"
WRAPPER_PATH="$HOME_DIR/.local/bin/ensure-kerberos-token-cron"
LOG_FILE="$HOME_DIR/.local/share/ensure-kerberos-token/cron.log"
MARKER_FILE="$HOME_DIR/check-kerberos-cron"

if [[ ! -x $SCRIPT_PATH ]]; then
    echo "Warning: $SCRIPT_PATH not found or not executable. Ensure the script is installed and executable." >&2
fi

MARKER_START="# BEGIN ensure-kerberos-token - dotfiles"
MARKER_END="# END ensure-kerberos-token - dotfiles"

CRON_SCHEDULE="*/${FREQ} * * * *"

CRON_JOB="$CRON_SCHEDULE \
    PATH=$HOME_DIR/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
    DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/${USER_ID}/bus \
    $WRAPPER_PATH"

write_wrapper() {
    mkdir -p "$(dirname "$LOG_FILE")"
    cat >"$WRAPPER_PATH" <<EOF
#!/usr/bin/env bash
# Auto-generated by setup-ensure-kerberos-cron — do not edit manually.
set -uo pipefail

output=\$("$SCRIPT_PATH" 2>&1)
rc=\$?

if [[ \$rc -ne 0 ]]; then
    printf '%s\n' "\$output" > "$LOG_FILE"
    ln -sf "$LOG_FILE" "$MARKER_FILE"
else
    rm -f "$MARKER_FILE"
fi
EOF
    chmod +x "$WRAPPER_PATH"
}

existing=$(crontab -l 2>/dev/null || true)

if [[ $ACTION == "install" ]]; then
    if grep -q "BEGIN ensure-kerberos-token" <<<"$existing"; then
        echo "ensure-kerberos-token cron job already installed. Use --update to replace or --uninstall to remove." >&2
        exit 0
    fi
    write_wrapper
    {
        echo "$existing"
        echo "$MARKER_START"
        echo "$CRON_JOB"
        echo "$MARKER_END"
    } | crontab -
    echo "Installed ensure-kerberos-token cron job (every ${FREQ} minutes)."
    echo "On error: marker at $MARKER_FILE, log at $LOG_FILE"
    exit 0
fi

if [[ $ACTION == "update" ]]; then
    # Regenerate the wrapper script (picks up any changes to paths/logic).
    write_wrapper
    # Replace the cron block in-place, whether it exists or not.
    stripped=$(echo "$existing" | sed '/BEGIN ensure-kerberos-token/,/END ensure-kerberos-token/d')
    {
        echo "$stripped"
        echo "$MARKER_START"
        echo "$CRON_JOB"
        echo "$MARKER_END"
    } | crontab -
    echo "Updated ensure-kerberos-token cron job (every ${FREQ} minutes)."
    echo "On error: marker at $MARKER_FILE, log at $LOG_FILE"
    exit 0
fi

if [[ $ACTION == "uninstall" ]]; then
    if ! grep -q "BEGIN ensure-kerberos-token" <<<"$existing"; then
        echo "No ensure-kerberos-token cron job found." >&2
        exit 0
    fi
    # Remove cron block between markers
    new=$(echo "$existing" | sed '/BEGIN ensure-kerberos-token/,/END ensure-kerberos-token/d')
    echo "$new" | crontab -
    rm -f "$WRAPPER_PATH" "$MARKER_FILE"
    echo "Removed ensure-kerberos-token cron job."
    exit 0
fi

echo "Unknown action" >&2
exit 2
